NODE_ENV=development
PORT=8787
DATABASE_URL=postgres://zaki:zaki@localhost:5433/zaki
NOVA_TYP_BASE_URL=https://typ.novanuggets.com
NOVA_TYP_API_KEY=
TOGETHER_API_KEY=
# D28 (sunset 2026-05-15): NULLALIS_* primary, NULLCLAW_* legacy fallback.
# Set whichever; the BFF reads dual-name and prefers NULLALIS_*. After
# sunset, the NULLCLAW_* names will be removed; migrate now.
NULLALIS_BASE_URL=http://127.0.0.1:3000
NULLALIS_INTERNAL_TOKEN=
# Local-only escape hatch: skip auth and hardcode a single user ID.
# Leave unset by default. Never use for multi-user smoke tests or hosted envs.
NULLALIS_DEV_USER_ID=
# Legacy aliases (sunset 2026-05-15 — uncomment if upgrading from old envs):
# NULLCLAW_BASE_URL=http://127.0.0.1:3000
# NULLCLAW_INTERNAL_TOKEN=
# NULLCLAW_DEV_USER_ID=
ZAKI_AGENT_BACKEND_ENABLED=false
# Must mirror nullalis `agent.telos_in_prompt`; exposed read-only in Settings.
ZAKI_AGENT_TELOS_IN_PROMPT=false
ZAKI_AGENT_WEBHOOK_BASE_URL=
ZAKI_AGENT_RATE_LIMIT_PER_MINUTE=60

# ZAKI Learn downstream service. Provider/model/API keys stay in the learning
# engine deployment secret, not in the browser or user-managed settings.
ZAKI_LEARNING_ENABLED=false
LEARNING_ENGINE_BASE_URL=http://127.0.0.1:8001
LEARNING_ENGINE_INTERNAL_TOKEN=
LEARNING_ENGINE_TENANT_DATA_ROOT=/data/users
ZAKI_LEARNING_ENGINE_IMAGE_TAG=
ZAKI_LEARNING_ENGINE_SOURCE_REPOSITORY=github.com/projectnuggets/zaki-learning-engine
ZAKI_LEARNING_ENGINE_SOURCE_COMMIT=
ZAKI_LEARNING_LLM_PROVIDER=together
ZAKI_LEARNING_LLM_MODEL=moonshotai/Kimi-K2.5
ZAKI_LEARNING_EMBEDDING_PROVIDER=together
ZAKI_LEARNING_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
ZAKI_LEARNING_SEARCH_PROVIDER=brave
ZAKI_LEARNING_MAX_REQUEST_BYTES=52428800
ZAKI_LEARNING_DAILY_PROMPT_LIMIT=5
ZAKI_LEARNING_BACKUPS_ENABLED=false
ZAKI_LEARNING_BACKUP_PROVIDER=
ZAKI_LEARNING_BACKUP_TARGET=
ZAKI_LEARNING_LAST_RESTORE_DRILL_AT=
ZAKI_LEARNING_RETENTION_CLEANUP_ENABLED=true

# Minutes read plane. Keep disabled until M5. Production uses the projected file;
# the direct token variable is a synthetic/local-development fallback only.
ZAKI_MINUTES_ENABLED=false
MINUTES_ENGINE_BASE_URL=http://127.0.0.1:8056
MINUTES_ENGINE_READ_TOKEN_FILE=
MINUTES_ENGINE_READ_TOKEN=
MINUTES_ENGINE_REQUEST_TIMEOUT_MS=10000

# Design dark-launch control plane. Keep both gates false until Infra explicitly
# approves activation. Directional tokens must be distinct; checkpoint
# credentials live only on the controller and the browser never receives them.
ZAKI_DESIGN_ENABLED=false
ZAKI_DESIGN_SESSION_CONTROLLER_ENABLED=false
ZAKI_DESIGN_CONTROLLER_BASE_URL=http://zaki-design-controller.design-sessions.svc.cluster.local:7460
ZAKI_DESIGN_CONTROLLER_TIMEOUT_MS=180000
ZAKI_DESIGN_CONTROLLER_TOKEN=
ZAKI_DESIGN_HUB_CALLBACK_TOKEN=

ZAKI_APP_CHAT_DAILY_PROMPT_LIMIT=10
ZAKI_APP_CHAT_DAILY_PROMPT_BUCKET=app_chat
ZAKI_ANONYMOUS_SPACES_DAILY_PROMPT_LIMIT=10
ZAKI_ANONYMOUS_SPACES_DAILY_PROMPT_BUCKET=anonymous_spaces
ZAKI_ANONYMOUS_SPACES_MODEL=openai/gpt-oss-120b
ZAKI_BOT_WEEKLY_PROMPT_LIMIT=10
ZAKI_BOT_WEEKLY_PROMPT_BUCKET=zaki_bot_weekly
ZAKI_LEARNING_WEEKLY_PROMPT_LIMIT=10
ZAKI_LEARNING_WEEKLY_PROMPT_BUCKET=learning_weekly
# Local-only bypass for specific accounts. Ignored in production.
ZAKI_LOCAL_UNLIMITED_QUOTA_EMAILS=
# Production must use explicit public origins only (no localhost/file://).
ZAKI_ALLOWED_ORIGINS=http://localhost:5173,file://
# Only super admins can add/remove admins in hidden admin page.
ZAKI_SUPER_ADMIN_EMAILS=as@novanuggets.com
# Legacy bootstrap allowlist (deprecated for runtime admin control).
ZAKI_ADMIN_EMAILS=
# Allowed values: console, smtp, resend, non
ZAKI_EMAIL_MODE=resend
ZAKI_PUBLIC_URL=http://localhost:8787
ZAKI_APP_URL=http://localhost:5173
ZAKI_DEFAULT_WORKSPACE_SLUG=zaky

# Google OAuth. Redirect URI must match the Google Cloud OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_STATE_SECRET=

# Optional override for memory extraction/relevance fallback path.
ZAKI_MEMORY_WORKSPACE_SLUG=
# Optional memory model for NOVA.TYP OpenAI-compatible chat path.
ZAKI_MEMORY_LLM_MODEL=gpt-4o-mini
# Must be explicitly set in production.
ZAKI_LEGAL_POLICY_VERSION=2026-07-12.v4
#
# --- Age policy (applies IDENTICALLY to email signup and Google OAuth) --------
# These two values are the ONLY place the age rule lives. Legal can change the
# policy by editing them; no code change, no per-auth-path surgery.
#
# ZAKI_AGE_GATE_ENABLED=true  (default) -> HARD DOB GATE.
#   Email signup: DOB collected and must be >= ZAKI_MINIMUM_SIGNUP_AGE.
#   Google OAuth: Google's `openid email profile` scope returns NO birthdate, so
#     a NEW Google account cannot be age-verified and is refused (the user is
#     told to sign up by email). Existing Google users sign in normally.
#
# ZAKI_AGE_GATE_ENABLED=false -> TOS ATTESTATION ONLY.
#   No DOB wall on either path. Consent is still recorded on both paths, always.
#   Google signup proceeds on the Terms attestation alone.
#
# Consent recording is NOT controlled by this flag. Every newly created account
# gets a legal_consent row at ZAKI_LEGAL_POLICY_VERSION on both paths, always.
ZAKI_AGE_GATE_ENABLED=true
# Draft legal threshold; owner/legal review must confirm before v4 is finalized.
ZAKI_MINIMUM_SIGNUP_AGE=16
# Optional: receive memory pipeline alerts in Slack/ops webhook.
ZAKI_MEMORY_ALERT_WEBHOOK_URL=
ZAKI_MEMORY_ALERT_WEBHOOK_TOKEN=
ZAKI_MEMORY_ALERT_TIMEOUT_MS=4000
# Required in production while metering fail-open is enabled: receives billing
# failures and critical degraded-mode paging alerts.
ZAKI_BILLING_ALERT_WEBHOOK_URL=
ZAKI_BILLING_ALERT_WEBHOOK_TOKEN=
ZAKI_BILLING_ALERT_TIMEOUT_MS=4000
ZAKI_BILLING_ALERT_COOLDOWN_MS=180000
# Number of most recent user messages scanned when session ends.
ZAKI_SESSION_MEMORY_MAX_USER_MESSAGES=8
# Safety caps for extraction volume during end-session processing.
ZAKI_SESSION_MEMORY_MAX_FACTS_PER_MESSAGE=8
ZAKI_SESSION_MEMORY_MAX_TOTAL_FACTS=64
ZAKI_ENABLE_SESSION_SUMMARIZATION=false  # set true to capture memories from whole conversations
# Chat memory retrieval (feels-known)
ZAKI_CHAT_MEMORY_VECTOR_ENABLED=true
# Embedder identity. Leave UNSET for all-MiniLM (English). Set to
# multilingual-e5-small when the chat engine's embedder is multilingual-e5 —
# enables the query:/passage: prefixing e5 requires (eval recall@5 0.778 -> 0.833;
# AnythingLLM does NOT prefix internally, so no double-prefix). MUST match the
# engine's configured embedder. See ops/2026-06-11-multilingual-embedder-switch.md.
ZAKI_MEMORY_EMBED_MODEL=
# Relevance floor. all-MiniLM: 0.1 (low absolute cosines for short query/fact
# pairs; 0.5 disabled recall). multilingual-e5-small: 0.72 (e5 cosines bunch high,
# real hits ~0.77-0.86; 0.72 keeps all hits and suppresses off-topic injection).
# Relevance is enforced mainly by cosine ORDER + top-k, not this floor.
ZAKI_CHAT_MEMORY_SEMANTIC_MIN=0.1
ZAKI_CHAT_MEMORY_EMBED_TIMEOUT_MS=1200
ZAKI_CHAT_MEMORY_IDENTITY_CORE_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ZAKI <mm@novanuggets.com>"
RESEND_API_KEY=
RESEND_FROM="ZAKI <mm@novanuggets.com>"

# Stripe (set in deployment secrets)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STUDENT=
STRIPE_PRICE_PERSONAL=
STRIPE_PRICE_STUDENT_YEARLY=
STRIPE_PRICE_PERSONAL_YEARLY=
# Commercial tiers (monthly price IDs). NOTE: no `_MONTHLY` suffix — these names
# match the deployed sandbox/prod secrets exactly.
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_MAX=
STRIPE_PRICE_ACCESS_CODE_MONTHLY=
STRIPE_BILLING_PORTAL_CONFIGURATION=
ZAKI_BILLING_PROVIDER=stripe
ZAKI_ACCESS_CODE_PURCHASE_CAMPAIGN=paid_monthly
ZAKI_ACCESS_CODE_PURCHASE_DURATION_DAYS=30

# Emergency metering backstop. Counters are deliberately in-process so they
# remain available during a metering database outage. The deployed BFF is
# single-replica; revisit the shared budget before enabling horizontal scaling.
ZAKI_METER_FAIL_OPEN_ENABLED=true
ZAKI_METER_FAIL_OPEN_WINDOW_MS=60000
ZAKI_METER_FAIL_OPEN_PER_USER_LIMIT_PER_MINUTE=3
ZAKI_METER_FAIL_OPEN_GLOBAL_BUDGET_PER_MINUTE=100
ZAKI_METER_FAIL_OPEN_PAGE_THRESHOLD_PER_MINUTE=10

# Paddle/external-link style checkout
ZAKI_EXTERNAL_CHECKOUT_URL_STUDENT=
ZAKI_EXTERNAL_CHECKOUT_URL_PERSONAL=
ZAKI_EXTERNAL_PORTAL_URL=
ZAKI_EXTERNAL_PROVIDER_LABEL=Paddle

# Creem checkout
CREEM_API_KEY=
CREEM_PRODUCT_ID_STUDENT=
CREEM_PRODUCT_ID_PERSONAL=
CREEM_API_BASE_URL=https://api.creem.io
CREEM_SUCCESS_URL=
CREEM_WEBHOOK_SECRET=
