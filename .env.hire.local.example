# Local-only Hire operator overrides.
# Copy to .env.hire.local. Do not commit .env.hire.local.

# Cost-free local E2E via host Ollama.
HIRE_LLM_PROVIDER=ollama
HIRE_LLM_MODEL=gemma4:26b
HIRE_OLLAMA_URL=http://host.docker.internal:11434/v1

# The provider smoke command blocks paid providers unless this is set to 1.
HIRE_PROVIDER_SMOKE_ALLOW_COST=0

# Local smoke tests still exercise the central meter. Raise this only for repeat local runs.
ZAKI_HIRE_WEEKLY_PROMPT_LIMIT=200

# Production profile belongs in ZAKI infra/Kubernetes secrets, not local source:
# HIRE_LLM_PROVIDER=kimi
# HIRE_LLM_MODEL=kimi-k2.5
# MOONSHOT_API_KEY=
