{
  "agents": {
    "defaults": {
      "model": {
        "primary": "together-ai/moonshotai/kimi-k2.5"
      }
    }
  },
  "models": {
    "providers": {
      "together-ai": {
        "api_key": "{{TOGETHER_API_KEY}}",
        "base_url": "https://api.together.xyz/v1"
      }
    }
  },
  "gateway": {
    "port": {{GATEWAY_PORT}},
    "host": "{{GATEWAY_HOST}}",
    "require_pairing": false,
    "allow_public_bind": true,
    "max_workers": 16,
    "max_queued_requests": 2048,
    "internal_service_tokens": ["{{INTERNAL_SERVICE_TOKEN}}"]
  },
  "tenant": {
    "enabled": true,
    "data_root": "{{TENANT_DATA_ROOT}}",
    "runtime_cache_max_users": 2048,
    "runtime_idle_ttl_secs": 1800
  },
  "state": {
    "backend": "{{STATE_BACKEND}}",
    "postgres": {
      "connection_string": "{{POSTGRES_RUNTIME_CONNECTION_STRING}}",
      "schema": "{{POSTGRES_SCHEMA}}",
      "pool_max": {{POSTGRES_POOL_MAX}},
      "statement_timeout_ms": {{POSTGRES_STATEMENT_TIMEOUT_MS}},
      "lock_timeout_ms": {{POSTGRES_LOCK_TIMEOUT_MS}}
    }
  },
  "composio": {
    "enabled": {{COMPOSIO_ENABLED}},
    "api_key": "{{COMPOSIO_API_KEY}}",
    "entity_id": "{{COMPOSIO_ENTITY_ID}}"
  },
  "session": {
    "cross_channel_shared_main": {{SESSION_SHARED_MAIN_BOOL}}
  },
  "channels": {
    "telegram": {
      "accounts": {
        "default": {
          "account_id": "default",
          "bot_token": "{{TELEGRAM_BOT_TOKEN}}",
          "receive_mode": "webhook",
          "webhook_secret_token": "{{TELEGRAM_WEBHOOK_SECRET}}",
          "allow_from": {{TELEGRAM_ALLOW_FROM_JSON}}
        }
      }
    }
  }
}
