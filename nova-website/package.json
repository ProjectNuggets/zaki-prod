{
  "name": "@nova-nuggets/website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4174",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "vite build && npm run build:ssr && npm run prerender && node scripts/validate-prerender.mjs",
    "build:dev": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4174"
  },
  "dependencies": {
    "lucide-react": "0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}
